{
  "name": "react-native-viewport-metrics",
  "version": "0.1.1",
  "description": "Coherent native viewport metrics snapshots for React Native and Expo.",
  "main": "./build/cjs/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "react-native": "./build/index.js",
  "browser": "./build/index.js",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "react-native": "./build/index.js",
      "browser": "./build/index.js",
      "import": "./build/esm/index.mjs",
      "require": "./build/cjs/index.js",
      "default": "./build/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android/build.gradle",
    "android/consumer-rules.pro",
    "android/src/main/**/*",
    "ios/**/*",
    "build/**/*.js",
    "build/**/*.mjs",
    "build/**/*.d.ts",
    "expo-module.config.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "expo-module build && node scripts/release/build-distribution.mjs",
    "clean": "expo-module clean",
    "commitlint": "commitlint --edit",
    "commitlint:head": "commitlint --from HEAD~1 --to HEAD --verbose",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "typecheck": "expo-module typecheck",
    "prepare": "npm run build && husky",
    "prepublishOnly": "node scripts/release/assert-publish-entrypoint.mjs",
    "expo-module": "expo-module",
    "example:prebuild:android": "npm --prefix example run prebuild:android",
    "example:prebuild:ios": "npm --prefix example run prebuild:ios",
    "example:build:debug:android": "npm --prefix example run build:debug:android",
    "example:build:debug:ios": "npm --prefix example run build:debug:ios",
    "example:build:debug": "npm run example:build:debug:android && npm run example:build:debug:ios",
    "example:open:android": "npm --prefix example run open:android",
    "example:open:ios": "npm --prefix example run open:ios",
    "e2e:metro": "npm --prefix example run start:detox",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test": "npm run e2e:test:ios && npm run e2e:test:android",
    "release:pack": "npm run build && node scripts/release/npm-pack-dry-run.mjs",
    "release:verify:unit": "npm run lint && npm test -- --runInBand --watchman=false && npm run typecheck && npm run compat:consumer-stack-smoke",
    "compat:consumer-stack-smoke": "node scripts/compat/check-consumer-stack-readiness.mjs && tsc -p compat/consumer-stack-smoke/tsconfig.json --noEmit",
    "release:build:native:android": "npm --prefix example run build:native:android && node scripts/release/assert-android-apk-keeps-viewport-metrics.mjs example/android/app/build/outputs/apk/release/app-release.apk",
    "release:build:native:ios": "npm --prefix example run build:native:ios",
    "release:build:native": "npm run release:build:native:android && npm run release:build:native:ios",
    "release:build:expo-dev:android": "npm --prefix example run build:expo-dev:android",
    "release:build:expo-dev:ios": "npm --prefix example run build:expo-dev:ios",
    "release:build:expo-dev": "npm run release:build:expo-dev:android && npm run release:build:expo-dev:ios",
    "release:build:eas-local:android": "npm run build && node scripts/release/run-eas-local-build.mjs android artifacts/eas-local/android-production.apk && node scripts/release/assert-android-apk-keeps-viewport-metrics.mjs artifacts/eas-local/android-production.apk",
    "release:build:eas-local:ios": "npm run build && node scripts/release/run-eas-local-build.mjs ios artifacts/eas-local/ios-production.tar.gz",
    "release:build:eas-local": "npm run release:build:eas-local:android && npm run release:build:eas-local:ios",
    "release:publish": "node scripts/release/npm-publish.mjs",
    "release:publish:dry-run": "node scripts/release/npm-publish-dry-run.mjs",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "expo",
    "viewport",
    "safe-area",
    "orientation",
    "worklets"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/le-ar/react-native-viewport-metrics.git"
  },
  "bugs": {
    "url": "https://github.com/le-ar/react-native-viewport-metrics/issues"
  },
  "author": "react-native-viewport-metrics contributors",
  "license": "MIT",
  "homepage": "https://github.com/le-ar/react-native-viewport-metrics#readme",
  "jest": {
    "preset": "expo-module-scripts"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "detox": "^20.50.1",
    "expo": "^55.0.15",
    "expo-module-scripts": "^55.0.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-reanimated": "^4.3.0",
    "react-native-worklets": "^0.8.1",
    "semver": "^7.7.3",
    "typescript": "^5.9.3"
  }
}
